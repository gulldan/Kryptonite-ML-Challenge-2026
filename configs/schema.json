{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "KryptoniteConfig",
    "type": "object",
    "required": [
        "paths",
        "runtime",
        "reproducibility",
        "training",
        "backends",
        "export",
        "tracking",
        "telemetry",
        "normalization",
        "vad",
        "augmentation_scheduler",
        "secrets",
        "deployment",
    ],
    "properties": {
        "paths": {
            "type": "object",
            "required": [
                "project_root",
                "dataset_root",
                "artifacts_root",
                "cache_root",
                "manifests_root",
            ],
            "properties": {
                "project_root": {"type": "string"},
                "dataset_root": {"type": "string"},
                "artifacts_root": {"type": "string"},
                "cache_root": {"type": "string"},
                "manifests_root": {"type": "string"},
            },
            "additionalProperties": false,
        },
        "runtime": {
            "type": "object",
            "required": ["seed", "device", "log_level", "num_workers"],
            "properties": {
                "seed": {"type": "integer", "minimum": 0},
                "device": {"type": "string"},
                "log_level": {"type": "string"},
                "num_workers": {"type": "integer", "minimum": 0},
            },
            "additionalProperties": false,
        },
        "reproducibility": {
            "type": "object",
            "required": ["deterministic", "pythonhashseed", "fingerprint_paths"],
            "properties": {
                "deterministic": {"type": "boolean"},
                "pythonhashseed": {"type": "integer", "minimum": 0},
                "fingerprint_paths": {"type": "array", "items": {"type": "string"}},
            },
            "additionalProperties": false,
        },
        "training": {
            "type": "object",
            "required": ["batch_size", "eval_batch_size", "max_epochs", "precision"],
            "properties": {
                "batch_size": {"type": "integer", "minimum": 1},
                "eval_batch_size": {"type": "integer", "minimum": 1},
                "max_epochs": {"type": "integer", "minimum": 1},
                "precision": {"type": "string"},
            },
            "additionalProperties": false,
        },
        "backends": {
            "type": "object",
            "required": ["inference", "export", "allow_torch", "allow_onnx", "allow_tensorrt"],
            "properties": {
                "inference": {
                    "type": "string",
                    "enum": ["auto", "onnx", "onnxruntime", "tensorrt", "torch"]
                },
                "export": {"type": "string", "enum": ["onnx", "torch"]},
                "allow_torch": {"type": "boolean"},
                "allow_onnx": {"type": "boolean"},
                "allow_tensorrt": {"type": "boolean"},
            },
            "additionalProperties": false,
        },
        "export": {
            "type": "object",
            "required": ["opset", "dynamic_axes", "profile", "boundary", "input_name", "output_name"],
            "properties": {
                "opset": {"type": "integer", "minimum": 1},
                "dynamic_axes": {"type": "boolean"},
                "profile": {"type": "string"},
                "boundary": {"type": "string", "enum": ["encoder_only"]},
                "input_name": {"type": "string", "minLength": 1},
                "output_name": {"type": "string", "minLength": 1},
            },
            "additionalProperties": false,
        },
        "tracking": {
            "type": "object",
            "required": [
                "enabled",
                "backend",
                "experiment",
                "run_name_prefix",
                "output_root",
                "copy_artifacts",
            ],
            "properties": {
                "enabled": {"type": "boolean"},
                "backend": {"type": "string"},
                "experiment": {"type": "string"},
                "run_name_prefix": {"type": "string"},
                "output_root": {"type": "string"},
                "copy_artifacts": {"type": "boolean"},
            },
            "additionalProperties": false,
        },
        "telemetry": {
            "type": "object",
            "required": ["enabled", "structured_logs", "metrics_enabled", "metrics_path"],
            "properties": {
                "enabled": {"type": "boolean"},
                "structured_logs": {"type": "boolean"},
                "metrics_enabled": {"type": "boolean"},
                "metrics_path": {"type": "string", "pattern": "^/.+"}
            },
            "additionalProperties": false
        },
        "normalization": {
            "type": "object",
            "required": [
                "target_sample_rate_hz",
                "target_channels",
                "output_format",
                "output_pcm_bits_per_sample",
                "peak_headroom_db",
                "dc_offset_threshold",
                "clipped_sample_threshold",
                "loudness_mode",
                "target_loudness_dbfs",
                "max_loudness_gain_db",
                "max_loudness_attenuation_db",
            ],
            "properties": {
                "target_sample_rate_hz": {"type": "integer", "minimum": 1},
                "target_channels": {"type": "integer", "minimum": 1},
                "output_format": {"type": "string", "enum": ["wav", "flac"]},
                "output_pcm_bits_per_sample": {"type": "integer", "minimum": 1},
                "peak_headroom_db": {"type": "number", "minimum": 0.0},
                "dc_offset_threshold": {"type": "number", "minimum": 0.0},
                "clipped_sample_threshold": {
                    "type": "number",
                    "exclusiveMinimum": 0.0,
                    "maximum": 1.0,
                },
                "loudness_mode": {"type": "string", "enum": ["none", "rms"]},
                "target_loudness_dbfs": {"type": "number"},
                "max_loudness_gain_db": {"type": "number", "minimum": 0.0},
                "max_loudness_attenuation_db": {"type": "number", "minimum": 0.0},
            },
            "additionalProperties": false,
        },
        "vad": {
            "type": "object",
            "required": [
                "mode",
                "backend",
                "provider",
                "min_output_duration_seconds",
                "min_retained_ratio",
            ],
            "properties": {
                "mode": {"type": "string", "enum": ["none", "light", "aggressive"]},
                "backend": {"type": "string", "enum": ["silero_vad_v6_onnx"]},
                "provider": {"type": "string", "enum": ["auto", "cpu", "cuda"]},
                "min_output_duration_seconds": {"type": ["number", "null"], "minimum": 0.0},
                "min_retained_ratio": {"type": ["number", "null"], "minimum": 0.0, "maximum": 1.0},
            },
            "additionalProperties": false,
        },
        "silence_augmentation": {
            "type": "object",
            "required": [
                "enabled",
                "max_leading_padding_seconds",
                "max_trailing_padding_seconds",
                "max_inserted_pauses",
                "min_inserted_pause_seconds",
                "max_inserted_pause_seconds",
                "pause_ratio_min",
                "pause_ratio_max",
                "min_detected_pause_seconds",
                "max_perturbed_pause_seconds",
                "analysis_frame_ms",
                "silence_threshold_dbfs"
            ],
            "properties": {
                "enabled": {"type": "boolean"},
                "max_leading_padding_seconds": {"type": "number", "minimum": 0.0},
                "max_trailing_padding_seconds": {"type": "number", "minimum": 0.0},
                "max_inserted_pauses": {"type": "integer", "minimum": 0},
                "min_inserted_pause_seconds": {"type": "number", "minimum": 0.0},
                "max_inserted_pause_seconds": {"type": "number", "minimum": 0.0},
                "pause_ratio_min": {"type": "number", "exclusiveMinimum": 0.0},
                "pause_ratio_max": {"type": "number", "exclusiveMinimum": 0.0},
                "min_detected_pause_seconds": {"type": "number", "minimum": 0.0},
                "max_perturbed_pause_seconds": {"type": "number", "minimum": 0.0},
                "analysis_frame_ms": {"type": "number", "exclusiveMinimum": 0.0},
                "silence_threshold_dbfs": {"type": "number"}
            },
            "additionalProperties": false
        },
        "augmentation_scheduler": {
            "type": "object",
            "required": [
                "enabled",
                "warmup_epochs",
                "ramp_epochs",
                "max_augmentations_per_sample",
                "clean_probability_start",
                "clean_probability_end",
                "light_probability_start",
                "light_probability_end",
                "medium_probability_start",
                "medium_probability_end",
                "heavy_probability_start",
                "heavy_probability_end",
                "family_weights"
            ],
            "properties": {
                "enabled": {"type": "boolean"},
                "warmup_epochs": {"type": "integer", "minimum": 0},
                "ramp_epochs": {"type": "integer", "minimum": 0},
                "max_augmentations_per_sample": {"type": "integer", "minimum": 1},
                "clean_probability_start": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "clean_probability_end": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "light_probability_start": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "light_probability_end": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "medium_probability_start": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "medium_probability_end": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "heavy_probability_start": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "heavy_probability_end": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "family_weights": {
                    "type": "object",
                    "required": ["noise", "reverb", "distance", "codec", "silence"],
                    "properties": {
                        "noise": {"type": "number", "exclusiveMinimum": 0.0},
                        "reverb": {"type": "number", "exclusiveMinimum": 0.0},
                        "distance": {"type": "number", "exclusiveMinimum": 0.0},
                        "codec": {"type": "number", "exclusiveMinimum": 0.0},
                        "silence": {"type": "number", "exclusiveMinimum": 0.0}
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "features": {
            "type": "object",
            "required": [
                "sample_rate_hz",
                "num_mel_bins",
                "frame_length_ms",
                "frame_shift_ms",
                "fft_size",
                "window_type",
                "f_min_hz",
                "power",
                "log_offset",
                "pad_end",
                "cmvn_mode",
                "cmvn_window_frames",
                "output_dtype",
            ],
            "properties": {
                "sample_rate_hz": {"type": "integer", "minimum": 1},
                "num_mel_bins": {"type": "integer", "minimum": 1},
                "frame_length_ms": {"type": "number", "exclusiveMinimum": 0.0},
                "frame_shift_ms": {"type": "number", "exclusiveMinimum": 0.0},
                "fft_size": {"type": "integer", "minimum": 1},
                "window_type": {"type": "string", "enum": ["hann", "hamming"]},
                "f_min_hz": {"type": "number", "minimum": 0.0},
                "f_max_hz": {"type": ["number", "null"]},
                "power": {"type": "number", "exclusiveMinimum": 0.0},
                "log_offset": {"type": "number", "exclusiveMinimum": 0.0},
                "pad_end": {"type": "boolean"},
                "cmvn_mode": {"type": "string", "enum": ["none", "sliding"]},
                "cmvn_window_frames": {"type": "integer", "minimum": 1},
                "output_dtype": {"type": "string", "enum": ["float16", "float32", "bfloat16"]},
            },
            "additionalProperties": false,
        },
        "feature_cache": {
            "type": "object",
            "required": [
                "namespace",
                "train_policy",
                "dev_policy",
                "infer_policy",
                "benchmark_device",
                "benchmark_warmup_iterations",
                "benchmark_iterations",
            ],
            "properties": {
                "namespace": {"type": "string", "minLength": 1},
                "train_policy": {
                    "type": "string",
                    "enum": ["precompute_cpu", "optional", "runtime"],
                },
                "dev_policy": {"type": "string", "enum": ["precompute_cpu", "optional", "runtime"]},
                "infer_policy": {
                    "type": "string",
                    "enum": ["precompute_cpu", "optional", "runtime"],
                },
                "benchmark_device": {"type": "string", "enum": ["auto", "cpu", "cuda"]},
                "benchmark_warmup_iterations": {"type": "integer", "minimum": 0},
                "benchmark_iterations": {"type": "integer", "minimum": 1},
            },
            "additionalProperties": false,
        },
        "chunking": {
            "type": "object",
            "required": [
                "train_min_crop_seconds",
                "train_max_crop_seconds",
                "train_num_crops",
                "train_short_utterance_policy",
                "eval_max_full_utterance_seconds",
                "eval_chunk_seconds",
                "eval_chunk_overlap_seconds",
                "eval_pooling",
                "demo_max_full_utterance_seconds",
                "demo_chunk_seconds",
                "demo_chunk_overlap_seconds",
                "demo_pooling",
            ],
            "properties": {
                "train_min_crop_seconds": {"type": "number", "exclusiveMinimum": 0.0},
                "train_max_crop_seconds": {"type": "number", "exclusiveMinimum": 0.0},
                "train_num_crops": {"type": "integer", "minimum": 1},
                "train_short_utterance_policy": {
                    "type": "string",
                    "enum": ["full", "repeat_pad", "zero_pad"],
                },
                "eval_max_full_utterance_seconds": {"type": "number", "exclusiveMinimum": 0.0},
                "eval_chunk_seconds": {"type": "number", "exclusiveMinimum": 0.0},
                "eval_chunk_overlap_seconds": {"type": "number", "minimum": 0.0},
                "eval_pooling": {"type": "string", "enum": ["mean", "max"]},
                "demo_max_full_utterance_seconds": {"type": "number", "exclusiveMinimum": 0.0},
                "demo_chunk_seconds": {"type": "number", "exclusiveMinimum": 0.0},
                "demo_chunk_overlap_seconds": {"type": "number", "minimum": 0.0},
                "demo_pooling": {"type": "string", "enum": ["mean", "max"]},
            },
            "additionalProperties": false,
        },
        "secrets": {
            "type": "object",
            "required": ["wandb_api_key", "mlflow_tracking_token", "huggingface_hub_token"],
            "properties": {
                "wandb_api_key": {"type": "string"},
                "mlflow_tracking_token": {"type": "string"},
                "huggingface_hub_token": {"type": "string"},
            },
            "additionalProperties": false,
        },
        "deployment": {
            "type": "object",
            "required": [
                "model_bundle_root",
                "demo_subset_root",
                "enrollment_cache_root",
                "require_artifacts"
            ],
            "properties": {
                "model_bundle_root": {"type": "string"},
                "demo_subset_root": {"type": "string"},
                "enrollment_cache_root": {"type": "string"},
                "require_artifacts": {"type": "boolean"},
            },
            "additionalProperties": false,
        },
    },
    "additionalProperties": false,
}
